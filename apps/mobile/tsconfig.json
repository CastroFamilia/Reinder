{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,
    "types": [
      "jest"
    ],
    "paths": {
      "@reinder/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@reinder/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../packages/shared/src/**/*.ts",
    "nativewind-env.d.ts"
  ]
}