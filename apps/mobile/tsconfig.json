{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,
    "paths": {
      "@reinder/shared": ["../../packages/shared/src/index.ts"],
      "@reinder/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../packages/shared/src/**/*.ts"]
}
