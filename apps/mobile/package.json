{
  "name": "@reinder/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@reinder/shared": "workspace:*",
    "@supabase/supabase-js": "^2.99.2",
    "expo": "~55.0.6",
    "expo-auth-session": "^55.0.9",
    "expo-blur": "~55.0.10",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "^55.0.8",
    "expo-secure-store": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.10",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "0.2.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!.pnpm|react-native|@react-native|expo|@expo|nativewind|tailwindcss|@testing-library)"
    ],
    "moduleNameMapper": {
      "^@reinder/shared/(.*)$": "<rootDir>/../../packages/shared/src/$1",
      "^@reinder/shared$": "<rootDir>/../../packages/shared/src/index.ts"
    }
  },
  "private": true
}
